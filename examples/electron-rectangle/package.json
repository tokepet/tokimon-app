{
  "name": "electron-rectangle",
  "version": "0.1.0",
  "private": true,
  "main": "dist/main/index.js",
  "scripts": {
    "build": "tsc",
    "start": "npm run build && electron .",
    "dev": "npm run build && electron .",
    "package": "npm run build && electron-builder"
  },
  "devDependencies": {
    "electron": "^31.0.0",
    "electron-builder": "^24.13.0",
    "typescript": "^5.4.0",
    "@types/node": "^20.12.0"
  },
  "build": {
    "appId": "com.tokimon.electron-rectangle",
    "productName": "ElectronRectangle",
    "files": ["dist/**/*", "src/renderer/index.html", "src/renderer/styles.css"],
    "mac": { "category": "public.app-category.developer-tools" },
    "win": { "target": "nsis" }
  }
}
